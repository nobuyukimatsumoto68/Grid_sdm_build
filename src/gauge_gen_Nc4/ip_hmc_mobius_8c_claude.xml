<?xml version="1.0"?>
<!-- 8^4 LOCAL DEBUG xml for dweofa_mobius_HSDM_v5_claude (CUDA TITAN V). -->
<!-- ColdStart (no config file needed). Mirrors the 32c m=0.01 action path -->
<!-- (Ls=16, M5=1.5, b=1.5, c=0.5, mass=0.01) so the EOFA + mixed-prec code -->
<!-- path is exercised identically. Few trajectories / few MD steps: this is a -->
<!-- correctness/debug run, NOT a perf test (8^4 is too well-conditioned to show -->
<!-- the MX_inner=10000 effect). -->
<grid>
  <HMC>
    <StartTrajectory>0</StartTrajectory>
    <Trajectories>3</Trajectories>
    <MetropolisTest>true</MetropolisTest>
    <NoMetropolisUntil>0</NoMetropolisUntil>
    <StartingType>ColdStart</StartingType>
    <PerformRandomShift>false</PerformRandomShift>
    <MD>
      <name>MinimumNorm2</name>
      <MDsteps>10</MDsteps>
      <trajL>1.0</trajL>
    </MD>
  </HMC>
  <Checkpointer>
    <config_prefix>./ckpoint_lat</config_prefix>
    <rng_prefix>./ckpoint_rng</rng_prefix>
    <saveInterval>1</saveInterval>
    <saveSmeared>false</saveSmeared>
    <smeared_prefix>./ckpoint_lat_smr</smeared_prefix>
    <format>IEEE64BIG</format>
  </Checkpointer>
  <RandomNumberGenerator>
    <serial_seeds>21 32 73 64 45</serial_seeds>
    <parallel_seeds>63 79 81 99 10</parallel_seeds>
  </RandomNumberGenerator>
  <Action>
    <gauge_beta>10.80</gauge_beta>
    <Mobius>
        <Ls>16</Ls>
        <mass>0.01</mass>
        <M5>1.5</M5>
        <b>1.5</b>
        <c>0.5</c>
        <StoppingCondition>1e-10</StoppingCondition>
        <MaxCGIterations>30000</MaxCGIterations>
        <ApplySmearing>false</ApplySmearing>
    </Mobius>
  </Action>
</grid>
