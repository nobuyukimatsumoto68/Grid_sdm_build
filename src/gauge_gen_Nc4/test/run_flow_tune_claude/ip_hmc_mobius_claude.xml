<?xml version="1.0"?>
<!--
  Template for dweofa_mobius_HSDM_v3 / v4 (Mobius EOFA HMC, SU(4) SDM).
  @BETA@ is replaced by run_hmc_claude.sh for each gauge_beta stream.
  Target tuning point: 32^3 x 64, m = 0.01, Ls = 16, M5 = 1.5 (b = 1.5, c = 0.5 -> Shamir-like).
  This is a thermalization scratch: short Trajectories, save every few traj.
-->
<grid>
  <HMC>
    <StartTrajectory>0</StartTrajectory>
    <Trajectories>40</Trajectories>          <!-- bump up once thermalization length is known -->
    <MetropolisTest>true</MetropolisTest>
    <NoMetropolisUntil>5</NoMetropolisUntil> <!-- skip accept/reject during early burn-in -->
    <StartingType>HotStart</StartingType>    <!-- ColdStart / CheckpointStart to continue -->
    <PerformRandomShift>false</PerformRandomShift>
    <MD>
      <name>MinimumNorm2</name>
      <MDsteps>30</MDsteps>
      <trajL>1.0</trajL>
    </MD>
  </HMC>
  <Checkpointer>
    <config_prefix>./ckpoint_lat</config_prefix>
    <rng_prefix>./ckpoint_rng</rng_prefix>
    <saveInterval>5</saveInterval>           <!-- saves ckpoint_lat.5, .10, ... a few configs -->
    <saveSmeared>false</saveSmeared>
    <smeared_prefix>./ckpoint_lat_smr</smeared_prefix>
    <format>IEEE64BIG</format>               <!-- NERSC double; eye4_anti reads this -->
  </Checkpointer>
  <RandomNumberGenerator>
    <serial_seeds>1 2 3 4 5</serial_seeds>
    <parallel_seeds>6 7 8 9 10</parallel_seeds>
  </RandomNumberGenerator>
  <Action>
    <gauge_beta>@BETA@</gauge_beta>
    <Mobius>
        <Ls>16</Ls>
        <mass>0.01</mass>
        <M5>1.5</M5>
        <b>1.5</b>
        <c>0.5</c>
        <StoppingCondition>1e-10</StoppingCondition>
        <MaxCGIterations>30000</MaxCGIterations>
        <ApplySmearing>false</ApplySmearing>
    </Mobius>
  </Action>
</grid>
